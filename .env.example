# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_key_here

# Gemini API ключи (14 ключей с ротацией)
GEMINI_K1=your_key_here
GEMINI_K2=your_key_here
GEMINI_K3=your_key_here
# ... до GEMINI_K14

# GROQ (опционально, для fallback)
GROQ_K1=your_key_here
GROQ_K2=your_key_here

# Edamam Nutrition API
EDAMAM_NUTR_ID=your_key_here
EDAMAM_NUTR_KEY=your_key_here

# Spoonacular API
SPOONACULAR_KEY=your_key_here
